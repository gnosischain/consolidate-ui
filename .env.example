# Validator indexer API (required) — powers /api/validators-by-address
GNOSIS_VALIDATORS_API_URL=
GNOSIS_VALIDATORS_API_KEY=
CHIADO_VALIDATORS_API_URL=
CHIADO_VALIDATORS_API_KEY=

# GraphQL endpoint for deposit-event lookups (optional) — /api/validate-deposit
GRAPHQL_URL=

# QuickNode RPC (optional) — only used to build the Ethereum mainnet/Sepolia
# CL endpoints (https://<endpoint>.quiknode.pro/<token>). Not needed for Gnosis/Chiado.
NEXT_PUBLIC_QUICKNODE_ENDPOINT=
NEXT_PUBLIC_QUICKNODE_TOKEN=
